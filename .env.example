# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=CronVend <hello@cronvend.com>
EMAIL_REPLY_TO=hello@cronvend.com
# Signing secret from Resend Dashboard → Webhooks → your endpoint → Signing secret
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Anthropic (Claude AI — for upsell copy)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Cron security
CRON_SECRET=generate-a-strong-random-secret

# Admin — protects POST /api/tenants/register (never expose this publicly)
ADMIN_SECRET=generate-a-strong-random-secret

# Flutterwave (billing)
# Secret key from FLW Dashboard → Settings → API
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxx
# Webhook hash from FLW Dashboard → Settings → Webhooks (set it yourself)
FLUTTERWAVE_WEBHOOK_HASH=generate-a-strong-random-secret
# Payment Plan IDs — create one plan per tier in FLW Dashboard → Payment Plans
FLUTTERWAVE_PLAN_MINI=12345
FLUTTERWAVE_PLAN_PRO=12346
FLUTTERWAVE_PLAN_MAX=12347

# Optional
DRY_RUN=false
SITE_URL=https://your-cronvend-domain.vercel.app
